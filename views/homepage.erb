      <div>
        <pre class="code-block"><code><span class="cmt"># Query orchards with pagination</span>
<span class="kw">POST</span> /genql
{
  <span class="str">"query"</span>: <span class="str">"</span>
    {
      orchards(first: <span class="num">3</span>) {
        nodes {
          name
          location
          varieties {
            name
            season
          }
        }
        page_info {
          has_next_page
          end_cursor
        }
      }
    }
  <span class="str">"</span>
}

<span class="cmt"># Record a harvest</span>
<span class="kw">POST</span> /genql
{
  <span class="str">"query"</span>: <span class="str">"mutation {
    addHarvest(
      orchard_id: \"o1\",
      variety_id: \"v1\",
      quantity_kg: <span class="num">800</span>,
      harvested_at: \"2025-09-01\"
    ) { id quantity_kg }
  }"</span>
}</code></pre>
