<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Scholar-Athlete // Saratoga</title>
  <style>
    /* ─── Reset & Base ──────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --orange:  #FF6200;
      --cyan:    #00E5FF;
      --yellow:  #FFE600;
      --dark:    #080808;
      --dark2:   #111111;
      --dark3:   #1A1A1A;
      --white:   #FFFFFF;
      --gray:    #888888;
      --radius:  4px;
      --font-hero: 'Arial Black', 'Arial Bold', 'Helvetica Neue', sans-serif;
      --font-body: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--dark);
      color: var(--white);
      font-family: var(--font-body);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Utility ────────────────────────────────────────────────────── */
    .sr-only {
      position: absolute; width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
      white-space: nowrap; border: 0;
    }

    /* ─── Nav ────────────────────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 2.5rem;
      background: linear-gradient(to bottom, rgba(8,8,8,0.95) 0%, transparent 100%);
    }

    .nav-logo {
      font-family: var(--font-hero);
      font-size: 1.1rem;
      font-weight: 900;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--white);
      text-decoration: none;
    }

    .nav-logo span { color: var(--orange); }

    .nav-links {
      display: flex; gap: 2rem; list-style: none;
    }

    .nav-links a {
      color: var(--gray);
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--white); }

    /* ─── Hero ───────────────────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 2.5rem 6rem;
      overflow: hidden;
      background: var(--dark);
    }

    /* Diagonal accent stripe */
    .hero::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -10%;
      width: 70%;
      height: 140%;
      background: linear-gradient(135deg, transparent 40%, rgba(255,98,0,0.06) 40%,
                  rgba(255,98,0,0.10) 60%, transparent 60%);
      transform: skewX(-8deg);
      pointer-events: none;
    }

    .hero::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background:
        radial-gradient(ellipse 60% 50% at 80% 50%, rgba(0,229,255,0.04) 0%, transparent 70%),
        radial-gradient(ellipse 40% 60% at 20% 80%, rgba(255,98,0,0.06) 0%, transparent 60%);
      pointer-events: none;
    }

    .hero-eyebrow {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 1.25rem;
      position: relative; z-index: 1;
    }

    .hero-headline {
      font-family: var(--font-hero);
      font-weight: 900;
      font-size: clamp(4rem, 12vw, 11rem);
      line-height: 0.88;
      letter-spacing: -0.03em;
      text-transform: uppercase;
      color: var(--white);
      max-width: 18ch;
      position: relative; z-index: 1;
    }

    .hero-headline .accent-orange { color: var(--orange); }
    .hero-headline .accent-cyan   { color: var(--cyan);   -webkit-text-stroke: 0; }

    /* Outlined text */
    .hero-headline .outline {
      -webkit-text-stroke: 2px var(--white);
      color: transparent;
    }

    .hero-sub {
      margin-top: 2.5rem;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      position: relative; z-index: 1;
    }

    .hero-tagline {
      font-size: clamp(1rem, 2.5vw, 1.35rem);
      font-weight: 400;
      color: rgba(255,255,255,0.65);
      max-width: 44ch;
      line-height: 1.55;
    }

    .hero-tagline strong {
      color: var(--white);
      font-weight: 700;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--orange);
      color: var(--white);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 900;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 2rem;
      clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 100%, 12px 100%);
      transition: background 0.2s, transform 0.15s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .hero-cta:hover {
      background: #ff7a20;
      transform: translateY(-2px);
    }

    .hero-cta svg { flex-shrink: 0; }

    /* Scroll indicator */
    .scroll-hint {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      z-index: 1;
      opacity: 0.4;
      animation: bounce 2.4s ease-in-out infinite;
    }

    .scroll-hint span {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    @keyframes bounce {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50%       { transform: translateX(-50%) translateY(8px); }
    }

    /* ─── Ticker ─────────────────────────────────────────────────────── */
    .ticker-wrap {
      overflow: hidden;
      background: var(--orange);
      padding: 0.85rem 0;
      border-top: 1px solid rgba(255,255,255,0.08);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .ticker-track {
      display: flex;
      width: max-content;
      animation: ticker 28s linear infinite;
    }

    .ticker-item {
      display: inline-flex;
      align-items: center;
      gap: 1.5rem;
      padding: 0 2.5rem;
      font-family: var(--font-hero);
      font-size: 0.75rem;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dark);
      white-space: nowrap;
    }

    .ticker-item .dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--dark);
      opacity: 0.5;
    }

    @keyframes ticker {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ─── Split Manifesto ────────────────────────────────────────────── */
    .split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 90vh;
    }

    .split-panel {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 5rem 3.5rem;
      overflow: hidden;
    }

    .split-panel--locker {
      background: var(--dark2);
      border-right: 1px solid rgba(255,255,255,0.05);
    }

    .split-panel--library {
      background: var(--dark3);
    }

    .split-panel__number {
      position: absolute;
      top: 3rem;
      right: 3.5rem;
      font-family: var(--font-hero);
      font-size: 10rem;
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.04em;
      color: rgba(255,255,255,0.03);
      pointer-events: none;
      user-select: none;
    }

    .split-panel__tag {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 1.5rem;
    }

    .split-panel--library .split-panel__tag {
      color: var(--cyan);
    }

    .split-panel__tag-line {
      display: inline-block;
      width: 2rem;
      height: 1px;
      background: currentColor;
    }

    .split-panel__title {
      font-family: var(--font-hero);
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 1.75rem;
    }

    .split-panel__body {
      font-size: 1rem;
      line-height: 1.7;
      color: rgba(255,255,255,0.55);
      max-width: 36ch;
    }

    .split-panel__body strong { color: var(--white); font-weight: 700; }

    /* ─── Stats Bar ──────────────────────────────────────────────────── */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      background: var(--dark2);
      border-top: 1px solid rgba(255,255,255,0.06);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .stat {
      padding: 3.5rem 2.5rem;
      border-right: 1px solid rgba(255,255,255,0.06);
      transition: background 0.2s;
    }

    .stat:last-child { border-right: none; }
    .stat:hover { background: rgba(255,255,255,0.025); }

    .stat__value {
      font-family: var(--font-hero);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
      color: var(--white);
    }

    .stat__value .unit {
      font-size: 0.55em;
      color: var(--orange);
      letter-spacing: 0;
    }

    .stat__label {
      margin-top: 0.75rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gray);
    }

    /* ─── Manifesto Quote ────────────────────────────────────────────── */
    .manifesto {
      position: relative;
      padding: 10rem 2.5rem;
      text-align: center;
      overflow: hidden;
      background: var(--dark);
    }

    .manifesto::before {
      content: '"';
      position: absolute;
      top: 3rem;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-hero);
      font-size: 28rem;
      line-height: 1;
      font-weight: 900;
      color: rgba(255,255,255,0.02);
      pointer-events: none;
      user-select: none;
    }

    .manifesto__inner {
      position: relative; z-index: 1;
      max-width: 900px;
      margin: 0 auto;
    }

    .manifesto__quote {
      font-family: var(--font-hero);
      font-size: clamp(1.8rem, 5vw, 3.5rem);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--white);
    }

    .manifesto__quote .hl-orange { color: var(--orange); }
    .manifesto__quote .hl-cyan   { color: var(--cyan); }

    .manifesto__author {
      margin-top: 2.5rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gray);
    }

    /* ─── Pillars Grid ───────────────────────────────────────────────── */
    .section {
      padding: 7rem 2.5rem;
    }

    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .section-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: var(--font-hero);
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 900;
      line-height: 0.92;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--white);
    }

    .pillars {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5px;
    }

    .pillar {
      background: var(--dark2);
      padding: 3rem 2.5rem;
      position: relative;
      overflow: hidden;
      transition: background 0.2s;
    }

    .pillar:hover { background: var(--dark3); }

    .pillar::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 2px;
      background: var(--orange);
      transition: width 0.3s ease;
    }

    .pillar:hover::after { width: 100%; }
    .pillar:nth-child(2)::after { background: var(--cyan); }
    .pillar:nth-child(5)::after { background: var(--yellow); }

    .pillar__icon {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      display: block;
    }

    .pillar__title {
      font-family: var(--font-hero);
      font-size: 1.25rem;
      font-weight: 900;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 1rem;
    }

    .pillar__body {
      font-size: 0.9rem;
      line-height: 1.65;
      color: rgba(255,255,255,0.5);
    }

    /* ─── Full-bleed CTA ─────────────────────────────────────────────── */
    .cta-band {
      position: relative;
      padding: 9rem 2.5rem;
      background: var(--orange);
      overflow: hidden;
      text-align: center;
    }

    .cta-band::before {
      content: 'FUEL';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: var(--font-hero);
      font-size: 30vw;
      font-weight: 900;
      letter-spacing: -0.05em;
      color: rgba(0,0,0,0.06);
      pointer-events: none;
      user-select: none;
      white-space: nowrap;
    }

    .cta-band__inner { position: relative; z-index: 1; }

    .cta-band__headline {
      font-family: var(--font-hero);
      font-size: clamp(2.5rem, 8vw, 6rem);
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: -0.03em;
      text-transform: uppercase;
      color: var(--dark);
    }

    .cta-band__sub {
      margin-top: 1.5rem;
      font-size: 1.1rem;
      color: rgba(0,0,0,0.6);
      max-width: 44ch;
      margin-left: auto;
      margin-right: auto;
    }

    .cta-band__actions {
      margin-top: 2.5rem;
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-dark {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--dark);
      color: var(--white);
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 2rem;
      clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 100%, 10px 100%);
      transition: background 0.2s;
    }

    .btn-dark:hover { background: #1a1a1a; }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: transparent;
      color: var(--dark);
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 2rem;
      border: 2px solid var(--dark);
      clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 100%, 10px 100%);
      transition: background 0.2s, color 0.2s;
    }

    .btn-ghost:hover { background: var(--dark); color: var(--orange); }

    /* ─── API Docs Section ───────────────────────────────────────────── */
    .api-section {
      padding: 7rem 2.5rem;
      background: var(--dark2);
    }

    .api-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 5rem;
      align-items: start;
      max-width: 1200px;
      margin: 0 auto;
    }

    .api-endpoint {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem;
      background: var(--dark3);
      border-left: 3px solid var(--orange);
      margin-bottom: 1rem;
      transition: border-color 0.2s;
    }

    .api-endpoint:nth-child(2) { border-color: var(--cyan); }
    .api-endpoint:nth-child(3) { border-color: var(--yellow); }
    .api-endpoint:hover { background: rgba(255,255,255,0.03); }

    .method-badge {
      font-family: var(--font-hero);
      font-size: 0.65rem;
      font-weight: 900;
      letter-spacing: 0.1em;
      padding: 0.25rem 0.6rem;
      flex-shrink: 0;
      clip-path: polygon(0 0, calc(100% - 5px) 0, 100% 100%, 5px 100%);
    }

    .method-get  { background: var(--cyan); color: var(--dark); }
    .method-post { background: var(--orange); color: var(--white); }

    .endpoint-path {
      font-family: monospace;
      font-size: 0.9rem;
      color: var(--white);
      margin-bottom: 0.25rem;
    }

    .endpoint-desc {
      font-size: 0.8rem;
      color: var(--gray);
    }

    .code-block {
      background: var(--dark);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: var(--radius);
      padding: 1.5rem;
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 0.78rem;
      line-height: 1.7;
      overflow-x: auto;
      color: rgba(255,255,255,0.8);
    }

    .code-block .kw  { color: var(--cyan); }
    .code-block .str { color: var(--yellow); }
    .code-block .cmt { color: rgba(255,255,255,0.3); }
    .code-block .num { color: var(--orange); }

    /* ─── Footer ─────────────────────────────────────────────────────── */
    footer {
      padding: 3rem 2.5rem;
      border-top: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .footer-logo {
      font-family: var(--font-hero);
      font-size: 0.9rem;
      font-weight: 900;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
    }

    .footer-logo span { color: var(--orange); }

    .footer-copy {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.25);
      letter-spacing: 0.05em;
    }

    /* ─── Responsive ─────────────────────────────────────────────────── */
    @media (max-width: 900px) {
      .split { grid-template-columns: 1fr; }
      .stats-bar { grid-template-columns: 1fr 1fr; }
      .stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
      .pillars { grid-template-columns: 1fr; }
      .api-grid { grid-template-columns: 1fr; gap: 3rem; }
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      .hero { padding: 0 1.5rem 5rem; }
      .hero-sub { flex-direction: column; align-items: flex-start; }
      .split-panel { padding: 4rem 2rem; }
      .section { padding: 5rem 1.5rem; }
    }

    @media (max-width: 600px) {
      .stats-bar { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav aria-label="Main navigation">
    <a href="/" class="nav-logo">Saro<span>·</span>GA</a>
    <ul class="nav-links" role="list">
      <li><a href="#mission">Mission</a></li>
      <li><a href="#pillars">Pillars</a></li>
      <li><a href="#api">API</a></li>
      <li><a href="/schema">Schema</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero" aria-labelledby="hero-heading">
    <p class="hero-eyebrow">The Next Generation &nbsp;/&nbsp; Scholar-Athlete Program</p>
    <h1 class="hero-headline" id="hero-heading">
      Lock&shy;er<br>
      Room<br>
      <span class="outline">Meets</span><br>
      <span class="accent-orange">Li&shy;brary</span>
    </h1>
    <div class="hero-sub">
      <p class="hero-tagline">
        Where <strong>champions are built</strong> in the weight room
        and <strong>futures are written</strong> in the study hall.
        One identity. Infinite potential.
      </p>
      <a href="#mission" class="hero-cta">
        Explore the mission
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
    <div class="scroll-hint" aria-hidden="true">
      <span>Scroll</span>
      <svg width="16" height="20" viewBox="0 0 16 20" fill="none">
        <path d="M8 2v16M2 13l6 6 6-6" stroke="white" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker-track">
      <!-- duplicated for seamless loop -->
      <% 2.times do %>
        <span class="ticker-item">Academic Excellence <span class="dot"></span></span>
        <span class="ticker-item">Athletic Discipline <span class="dot"></span></span>
        <span class="ticker-item">Leadership On & Off The Field <span class="dot"></span></span>
        <span class="ticker-item">Scholarship &amp; Sport <span class="dot"></span></span>
        <span class="ticker-item">Fuel Your Mind <span class="dot"></span></span>
        <span class="ticker-item">Fuel Your Body <span class="dot"></span></span>
        <span class="ticker-item">Scholar · Athlete · Leader <span class="dot"></span></span>
        <span class="ticker-item">Train Hard. Study Harder. <span class="dot"></span></span>
      <% end %>
    </div>
  </div>

  <!-- SPLIT MANIFESTO -->
  <section id="mission" aria-label="Mission">
    <div class="split">
      <div class="split-panel split-panel--locker">
        <span class="split-panel__number" aria-hidden="true">01</span>
        <div class="split-panel__tag">
          <span class="split-panel__tag-line"></span>
          The Locker Room
        </div>
        <h2 class="split-panel__title">Where Grit<br>Gets Built</h2>
        <p class="split-panel__body">
